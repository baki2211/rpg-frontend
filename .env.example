# Copy to `.env.local` and adjust as needed. All variables are optional —
# `src/config/api.ts` auto-detects the right backend in most cases. See
# `docs/setup.md` for the full detection rules.

# Force the app to use the local backend even when the host/port heuristics
# would otherwise pick production. Useful when previewing a production build
# against a local backend on a non-localhost host. Set to `false` to force
# production instead — needed when the app is served on an internal corp
# domain (e.g. *.local, 10.x.x.x) that would otherwise be auto-detected as
# local.
# NEXT_PUBLIC_USE_LOCAL_BACKEND=true

# Override the local REST and WebSocket base URLs (only consulted when the app
# resolves to "local").
# NEXT_PUBLIC_LOCAL_BACKEND_URL=http://localhost:5001
# NEXT_PUBLIC_LOCAL_WS_URL=ws://localhost:5001

# Override the production REST and WebSocket base URLs (only consulted when
# the app resolves to "production"). Leave unset to fall back to
# https://arcanerealms.org / wss://arcanerealms.org.
# NEXT_PUBLIC_BACKEND_URL=https://arcanerealms.org
# NEXT_PUBLIC_WS_URL=wss://arcanerealms.org
